// FILE: prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                    String        @id @default(cuid())
  kick_user_id          String?       @unique
  kick_username         String?
  email                 String?       @unique
  avatar                String?
  access_token          String?
  refresh_token         String?
  kick_token_expires_at DateTime?
  points                Int           @default(0)
  isAdmin               Boolean       @default(false)
  isKickBroadcaster     Boolean       @default(false)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  bio                   String?
  display_name          String?
  profile_accent        String?
  raffleEntries         RaffleEntry[]
}

model KickReward {
  id                                    String   @id @default(cuid())
  kick_reward_id                        String   @unique
  title                                 String
  description                           String?
  cost                                  Int
  background_color                      String?
  is_enabled                            Boolean  @default(true)
  is_paused                             Boolean  @default(false)
  is_user_input_required                Boolean  @default(false)
  should_redemptions_skip_request_queue Boolean  @default(false)
  raw_json                              Json?
  createdAt                             DateTime @default(now())
  updatedAt                             DateTime @updatedAt
}

model SiteSettings {
  id         String   @id @default("site-settings")
  kickUrl    String
  discordUrl String?
  youtubeUrl String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model LeaderboardSettings {
  id              String                 @id @default("leaderboard-settings")
  title           String
  subtitle        String
  countdownTarget DateTime
  startDate       DateTime?
  endDate         DateTime?
  prizeTiers      LeaderboardPrizeTier[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
}

model LeaderboardPrizeTier {
  id            String              @id @default(cuid())
  leaderboardId String
  place         Int
  prize         Int
  leaderboard   LeaderboardSettings @relation(fields: [leaderboardId], references: [id], onDelete: Cascade)

  @@unique([leaderboardId, place])
}

model Raffle {
  id                String        @id
  title             String
  description       String?
  image             String?
  status            String        @default("active")
  entryMethod       String
  entryCost         Int           @default(0)
  entryCurrency     String        @default("bullets")
  maxEntriesPerUser Int?
  totalEntries      Int           @default(0)
  startDate         DateTime
  endDate           DateTime
  winner            String?
  prizeDetails      String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  entries           RaffleEntry[]

  @@index([status])
  @@index([endDate])
  @@index([createdAt])
}

model RaffleEntry {
  id        String   @id @default(cuid())
  raffleId  String
  userId    String
  cost      Int      @default(0)
  currency  String   @default("bullets")
  createdAt DateTime @default(now())

  raffle Raffle @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([raffleId])
  @@index([userId])
  @@index([createdAt])
}

model Challenge {
  id              String   @id
  title           String
  description     String?
  status          String   @default("active")
  goal            Int
  currentProgress Int      @default(0)
  reward          String
  startDate       DateTime
  endDate         DateTime
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([endDate])
  @@index([createdAt])
}