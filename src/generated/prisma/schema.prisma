generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String  @id @default(cuid())
  kick_user_id  String? @unique
  kick_username String?
  email         String? @unique
  avatar        String?

  access_token          String?
  refresh_token         String?
  kick_token_expires_at DateTime?

  points Int @default(0)

  // ✅ NEW PROFILE FIELDS
  display_name   String?
  bio            String?
  profile_accent String?

  isAdmin           Boolean @default(false)
  isKickBroadcaster Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model KickReward {
  id                                    String  @id @default(cuid())
  kick_reward_id                        String  @unique
  title                                 String
  description                           String?
  cost                                  Int
  background_color                      String?
  is_enabled                            Boolean @default(true)
  is_paused                             Boolean @default(false)
  is_user_input_required                Boolean @default(false)
  should_redemptions_skip_request_queue Boolean @default(false)
  raw_json                              Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
