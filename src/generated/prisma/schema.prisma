generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String           @id @default(cuid())
  kick_user_id            String?          @unique
  kick_username           String?
  email                   String?          @unique
  avatar                  String?
  access_token            String?
  refresh_token           String?
  kick_token_expires_at   DateTime?
  points                  Int              @default(0)
  isAdmin                 Boolean          @default(false)
  isKickBroadcaster       Boolean          @default(false)
  createdAt               DateTime         @default(now())
  updatedAt               DateTime         @updatedAt
  bio                     String?
  display_name            String?
  profile_accent          String?
  raffleEntries           RaffleEntry[]
  challengeClaims         ChallengeClaim[] @relation("ChallengeClaimUser")
  reviewedChallengeClaims ChallengeClaim[] @relation("ChallengeClaimReviewer")
}

model KickReward {
  id                                    String   @id @default(cuid())
  kick_reward_id                        String   @unique
  title                                 String
  description                           String?
  cost                                  Int
  background_color                      String?
  is_enabled                            Boolean  @default(true)
  is_paused                             Boolean  @default(false)
  is_user_input_required                Boolean  @default(false)
  should_redemptions_skip_request_queue Boolean  @default(false)
  raw_json                              Json?
  createdAt                             DateTime @default(now())
  updatedAt                             DateTime @updatedAt
}

model SiteSettings {
  id           String   @id @default("site-settings")
  kickUrl      String
  discordUrl   String?
  youtubeUrl   String?
  xUrl         String?
  instagramUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model LeaderboardSettings {
  id              String                 @id @default("leaderboard-settings")
  title           String
  subtitle        String
  countdownTarget DateTime
  startDate       DateTime?
  endDate         DateTime?
  prizeTiers      LeaderboardPrizeTier[]
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
}

model LeaderboardPrizeTier {
  id            String              @id @default(cuid())
  leaderboardId String
  place         Int
  prize         Int
  leaderboard   LeaderboardSettings @relation(fields: [leaderboardId], references: [id], onDelete: Cascade)

  @@unique([leaderboardId, place])
}

model Raffle {
  id                String        @id
  title             String
  description       String?
  image             String?
  status            String        @default("active")
  entryMethod       String
  entryCost         Int           @default(0)
  entryCurrency     String        @default("bullets")
  maxEntriesPerUser Int?
  totalEntries      Int           @default(0)
  startDate         DateTime
  endDate           DateTime
  winner            String?
  prizeDetails      String
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  entries           RaffleEntry[]

  @@index([status])
  @@index([endDate])
  @@index([createdAt])
}

model RaffleEntry {
  id        String   @id @default(cuid())
  raffleId  String
  userId    String
  cost      Int      @default(0)
  currency  String   @default("bullets")
  createdAt DateTime @default(now())

  raffle Raffle @relation(fields: [raffleId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([raffleId])
  @@index([userId])
  @@index([createdAt])
}

model Challenge {
  id            String           @id
  title         String
  description   String?
  status        String           @default("active")
  challengeType String           @default("multiplier")
  targetValue   Float
  minBet        Float            @default(0.2)
  reward        String
  rules         String?
  slotName      String?
  provider      String?
  imageUrl      String?
  imageSource   String?
  claimLimit    Int              @default(1)
  requiresProof Boolean          @default(true)
  startDate     DateTime
  endDate       DateTime
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  claims        ChallengeClaim[]

  @@index([status])
  @@index([endDate])
  @@index([createdAt])
}

model ChallengeClaim {
  id              String    @id @default(cuid())
  challengeId     String
  userId          String
  proofImageUrl   String
  note            String?
  status          String    @default("pending")
  rejectionReason String?
  reviewedAt      DateTime?
  reviewedById    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  challenge  Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user       User      @relation("ChallengeClaimUser", fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User?     @relation("ChallengeClaimReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([challengeId])
  @@index([userId])
  @@index([status])
  @@index([createdAt])
}

model Tournament {
  id               String            @id @default("slot-tournament")
  title            String
  description      String?
  status           String            @default("draft")
  championName     String?
  championSlotName String?
  bracketSize      Int               @default(8)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  matches          TournamentMatch[]
}

model TournamentMatch {
  id              String     @id @default(cuid())
  tournamentId    String
  round           Int
  matchNumber     Int
  leftViewerName  String?
  rightViewerName String?
  leftSlotName    String?
  rightSlotName   String?
  leftPayout      Float      @default(0)
  rightPayout     Float      @default(0)
  winnerSide      String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  tournament      Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, round, matchNumber])
  @@index([tournamentId, round])
  @@index([updatedAt])
}
